rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────
    // HELPERS
    // ────────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }

    function userExists() {
      return isAuth() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }
    function userProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    function userDept() {
      return userExists() ? userProfile().depto : '';
    }
    function userRol() {
      return userExists() ? userProfile().rol : '';
    }
    function isAdmin() { return userRol() == 'admin'; }
    function isCEO() { return userDept() == 'CEO'; }
    function isAdminOrCEO() {
      return isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    function isCalidad() {
      return isAuth() && (isAdmin() || userDept() in ['CAL','ALP','CEO','ADMIN']);
    }
    function isCS() {
      return isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEO','ADMIN']);
    }
    function isProduccion() {
      return isAuth() && (isAdmin() || userDept() in ['PRO','PLN','CEO','ADMIN']);
    }
    function isLogistica() {
      return isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CEO','ADMIN']);
    }
    function isCompras() {
      return isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
    }
    function isComercial() {
      return isAuth() && (isAdmin() || userDept() in ['CS','KAM','COMP','CEO','ADMIN']);
    }
    // 🆕 Facturación y Crédito y Cobranza
    function isFacturacion() {
      return isAuth() && (isAdmin() || userDept() in ['FAC','CEO','ADMIN']);
    }
    function isCreditoYCobranza() {
      return isAuth() && (isAdmin() || userDept() in ['CYC','CEO','ADMIN']);
    }
    function isFacOCyC() {
      return isAuth() && (isAdmin() || userDept() in ['FAC','CYC','CEO','ADMIN']);
    }

    // ────────────────────────────────────────────────────────────
    // USUARIOS
    // ────────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == uid || isAdminOrCEO());
      allow update: if isAuth() && (isAdminOrCEO() || request.auth.uid == uid);
      allow delete: if isAuth() && isAdminOrCEO();
    }

    // ────────────────────────────────────────────────────────────
    // CATÁLOGOS GENERALES
    // ────────────────────────────────────────────────────────────
    // 🆕 CLIENTES: FAC y CYC pueden editar datos fiscales y código
    match /clientes/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN','FAC','CYC'];
    }

    match /productos_pt/{id} {
      allow read: if isAuth();
      allow create: if isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN'];
      allow update: if isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN','PRO','PLN','CAL','ALP'];
      allow delete: if isAdmin() || userDept() in ['CEO','ADMIN'];
    }

    match /cliente_productos/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN'];
    }

    match /almacenes/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // PEDIDOS Y ÓRDENES DE VENTA
    // ────────────────────────────────────────────────────────────
    // 🆕 PEDIDOS: FAC y CYC pueden leer/actualizar (autorizar crédito, marcar facturado)
    match /pedidos/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN','CAL','ALP']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN','PLN','CAL','ALP','CEDMTY','CEDMEX','FAC','CYC']);
      allow delete: if isAdmin();
    }

    match /pedido_lineas/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN','CAL','ALP']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEO','COMP','ADMIN','CAL','ALP','FAC','CYC']);
      allow delete: if isAdmin();
    }

    // 🆕 ORDENES DE VENTA: FAC y CYC pueden actualizar
    match /ordenes_venta/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN','CS','KAM']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CAL','ALP','CEDMTY','CEDMEX','CEO','ADMIN','FAC','CYC']);
      allow delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // PRODUCCIÓN
    // ────────────────────────────────────────────────────────────
    match /ordenes_produccion/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN','PLN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN','CAL','ALP','CS','KAM','CEDMTY','CEDMEX']);
      allow delete: if isAdmin();
    }

    match /capturas_produccion/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PRO','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['PRO','PLN','CEO','ADMIN']);
      allow delete: if isAdmin();
    }

    match /rollos_extrusion/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PRO','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['PRO','PLN','CEO','ADMIN']);
      allow delete: if isAdmin();
    }

    match /lotes/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PRO','CAL','ALP','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','PRO','CAL','CEO','ADMIN','CS','KAM']);
      allow delete: if isAdmin();
    }

    match /tarimas/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CAL','ALP','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CAL','CEO','ADMIN','CS','KAM']);
      allow delete: if isAdmin();
    }

    match /packing_lists/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CAL','ALP','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CAL','ALP','CEO','ADMIN','CS','KAM']);
      allow delete: if isAdmin();
    }

    // 🆕 SALIDAS PARCIALES ("Jalar y liberar" / dar salida a material registrado)
    match /salidas_parciales/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CAL','ALP','CS','KAM','CEDMTY','CEDMEX','PLN','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CAL','ALP','CS','KAM','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAdmin();
    }

    // 🆕 SOLICITUDES URGENTES (comercial pide salida urgente, calidad/logística la atiende)
    match /solicitudes_urgentes/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CAL','ALP','CS','KAM','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAdmin();
    }

    match /oti/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAdmin();
    }

    match /transportistas/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /operadores_logistica/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /unidades_logistica/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    // 🆕 REMISIONES — FAC y CYC pueden actualizar (concilia con facturas)
    match /remisiones/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CS','KAM','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CS','KAM','CEO','ADMIN','FAC','CYC']);
      allow delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // 🆕 FACTURACIÓN, CRÉDITO Y COBRANZA
    // ────────────────────────────────────────────────────────────
    match /facturas/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['FAC','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /cobros/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['CYC','FAC','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /movimientos_credito/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CYC','FAC','CEO','ADMIN']);
      allow update, delete: if isAdmin();
    }

    match /expedientes_credito/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in ['CYC','FAC','CS','KAM','CEO','ADMIN']);
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['CYC','FAC','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    // ────────────────────────────────────────────────────────────
    // 🆕 PELETIZADO (P-5) — merma clasificada por Material × Color
    // ────────────────────────────────────────────────────────────
    match /lotes_peletizado/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PRO','PLN','ALP','CAL','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /movimientos_merma/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PRO','PLN','ALP','CAL','CEO','ADMIN']);
      allow update, delete: if isAdmin(); // historial inmutable
    }

    match /corridas_peletizado/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PRO','PLN','CEO','ADMIN']);
      allow update, delete: if isAdmin();
    }

    match /almacen_desecho_venta/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PRO','PLN','CS','COMP','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    // ────────────────────────────────────────────────────────────
    // COMUNICACIÓN
    // ────────────────────────────────────────────────────────────
    match /comentarios_pedidos/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notificaciones/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth();
    }

    // ────────────────────────────────────────────────────────────
    // MÁQUINAS Y PERSONAL
    // ────────────────────────────────────────────────────────────
    match /maquinas/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PLN','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['PLN','CEO','ADMIN']);
    }

    match /operadores/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
    }

    match /supervisores/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
    }

    // ────────────────────────────────────────────────────────────
    // MATERIAS PRIMAS
    // ────────────────────────────────────────────────────────────
    match /materias_primas/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['COMP','PLN','PRO','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['COMP','ADMIN','CEO']);
    }

    match /movimientos_mp/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /lotes_mp/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['ALP','COMP','CEO','PRO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    // ────────────────────────────────────────────────────────────
    // COMPRAS (RC, OC, PROVEEDORES)
    // ────────────────────────────────────────────────────────────
    match /requisiciones_compras/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
    }

    match /ordenes_compra/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
      // 🆕 FAC también edita OCs (facturas de proveedores)
      allow update: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN','ALP','CEDMTY','CEDMEX','FAC']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
    }

    match /proveedores/{id} {
      allow read: if isAuth();
      // 🆕 FAC y CYC editan datos fiscales de proveedores
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN','FAC','CYC']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
    }

    // ────────────────────────────────────────────────────────────
    // ESTANDARIZACIÓN
    // ────────────────────────────────────────────────────────────
    match /estandarizacion_historial/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CAL','ALP','CEO','ADMIN']);
      allow update, delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    // ────────────────────────────────────────────────────────────
    // 🔧 MTTO
    // ────────────────────────────────────────────────────────────
    match /productos_mtto/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in ['MTTO','COMP','CEO','ADMIN','ALP']);
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['MTTO','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /movimientos_mtto/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in ['MTTO','COMP','CEO','ADMIN','ALP']);
      allow create: if isAuth() && (isAdmin() || userDept() in ['MTTO','COMP','CEO','ADMIN','ALP']);
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────
    // 📦 EMPAQUE
    // ────────────────────────────────────────────────────────────
    match /productos_empaque/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','COMP','CEO','ADMIN']);
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','COMP','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /movimientos_empaque/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','COMP','CEO','ADMIN']);
      allow create: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','COMP','CEO','ADMIN']);
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────
    // 🖇️ OFICINA — FAC y CYC también lo necesitan
    // ────────────────────────────────────────────────────────────
    match /productos_oficina/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in [
        'ALP','CEDMTY','CEDMEX','ADMIN','COMP','CEO',
        'CS','KAM','PLN','PRO','CAL','MTTO','FAC','CYC'
      ]);
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['ADMIN','COMP','CEO']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /movimientos_oficina/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in [
        'ALP','CEDMTY','CEDMEX','ADMIN','COMP','CEO',
        'CS','KAM','PLN','PRO','CAL','MTTO','FAC','CYC'
      ]);
      allow create: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','ADMIN','COMP','CEO','FAC','CYC']);
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────
    // 🛒 COMERCIALIZADO
    // ────────────────────────────────────────────────────────────
    match /productos_comercializados/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEDMTY','CEDMEX','COMP','CEO','ADMIN']);
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['CS','COMP','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }

    match /movimientos_comercializados/{id} {
      allow read: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEDMTY','CEDMEX','COMP','CEO','ADMIN']);
      allow create: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','CEDMTY','CEDMEX','ALP','COMP','CEO','ADMIN']);
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────
    // CONTADORES (FOLIOS)
    // ────────────────────────────────────────────────────────────
    match /contadores/{id} {
      allow read, write: if isAuth();
    }
  }
}
