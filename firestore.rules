rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isAuth() { return request.auth != null; }
    function userProfile() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data; }
    function isAdmin() { return isAuth() && userProfile().rol == 'admin'; }
    function userDept() { return isAuth() ? userProfile().depto : ''; }
    function isCEO() { return userDept() == 'CEO'; }
    function isAdminOrCEO() { return isAuth() && (userProfile().rol == 'admin' || userProfile().depto == 'CEO' || userProfile().depto == 'ADMIN'); }
    
    // Usuarios: lectura para todos los autenticados (necesario para listar en panel admin)
    // Escritura: admin/CEO/ADMIN pueden gestionar a cualquiera; cada quien puede editar su propio perfil básico
    match /usuarios/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && isAdminOrCEO();
      allow update: if isAuth() && (isAdminOrCEO() || request.auth.uid == uid);
      allow delete: if isAuth() && isAdminOrCEO();
    }
    
    // Catálogos: cualquier usuario autenticado lee; solo admin/CS escribe
    match /clientes/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || userDept() in ['CS','CEO','COMP','ADMIN'];
    }
    
    match /productos_pt/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || userDept() in ['CS','CEO','COMP','ADMIN'];
    }
    
    match /cliente_productos/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || userDept() in ['CS','CEO','COMP','ADMIN'];
    }
    
    match /almacenes/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // Pedidos: lectura abierta a todos los autenticados; creación CS/CEO/COMP/ADMIN
    match /pedidos/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CS','CEO','COMP','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CS','CEO','COMP','ADMIN','PLN']);
      allow delete: if isAdmin();
    }
    
    match /pedido_lineas/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CS','CEO','COMP','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CS','CEO','COMP','ADMIN']);
      allow delete: if isAdmin();
    }
    
    // Órdenes de venta: lectura abierta; CS/KAM asignan, CEDIS prepara, CS genera remisión, CEDIS confirma carga
    match /ordenes_venta/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CS','KAM','ALP','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAdmin();
    }
    
    // Órdenes de producción: PLN/PRO/CEO/ADMIN gestionan
    match /ordenes_produccion/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
      allow delete: if isAdmin();
    }
    
    // Capturas de producción: PRO/CEO/ADMIN crean; todos leen
    match /capturas_produccion/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PRO','CEO','ADMIN']);
      allow update, delete: if isAdmin();
    }
    
    // Lotes de producción: PRO/CEO/ADMIN crean; ALP/CEDMTY/CEDMEX actualizan (cantidad disponible)
    match /lotes/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['PRO','CAL','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','PRO','CAL','CEO','ADMIN']);
      allow delete: if isAdmin();
    }
    
    // Tarimas (con QR): generadas al liberar calidad
    match /tarimas/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CAL','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CAL','CEO','ADMIN']);
      allow delete: if isAdmin();
    }
    
    // Packing Lists: generados al liberar calidad
    match /packing_lists/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['CAL','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['CAL','CEO','ADMIN']);
      allow delete: if isAdmin();
    }
    
    // OTI (Órdenes de Transferencia Interna): ALP crea, CEDMTY/CEDMEX recibe
    match /oti/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEO','ADMIN']);
      allow update: if isAuth() && (isAdmin() || userDept() in ['ALP','CEDMTY','CEDMEX','CEO','ADMIN']);
      allow delete: if isAdmin();
    }
    
    // Comentarios en pedidos: cualquier autenticado puede leer y crear; solo admin elimina
    match /comentarios_pedidos/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Notificaciones: lectura para todos; cualquier usuario autenticado puede crear
    match /notificaciones/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    
    // Máquinas de producción: lectura abierta; PLN/CEO/ADMIN escriben
    match /maquinas/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PLN','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['PLN','CEO','ADMIN']);
    }
    
    // Operadores: lectura abierta; PLN/PRO/CEO/ADMIN escriben
    match /operadores/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
    }
    
    // Supervisores: lectura abierta; PLN/PRO/CEO/ADMIN escriben
    match /supervisores/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['PLN','PRO','CEO','ADMIN']);
    }
    
    // Materias Primas: lectura abierta; COMP/ADMIN/CEO escriben
    match /materias_primas/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['COMP','ADMIN','CEO']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['COMP','ADMIN','CEO']);
    }
    
    // Requisiciones de compra: cualquier autenticado crea/lee; solo COMP/CEO aprueban
    match /requisiciones_compras/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
    }
    
    // Órdenes de compra: COMP/CEO escriben, todos leen
    match /ordenes_compra/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['COMP','CEO','ADMIN']);
    }
    
    // Lotes de MP: ALP/COMP/CEO crean al recibir, todos leen
    match /lotes_mp/{id} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (isAdmin() || userDept() in ['ALP','COMP','CEO','PRO','ADMIN']);
      allow delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }
    
    // Movimientos de MP (kardex): cualquier proceso autorizado escribe
    match /movimientos_mp/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && (isAdmin() || userDept() in ['CEO','ADMIN']);
    }
    
    // Contadores: cualquier autenticado los actualiza (vía transacción) para folios
    match /contadores/{id} {
      allow read, write: if isAuth();
    }
  }
}
